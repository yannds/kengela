{
  "name": "@kengela/adapter-directory-ldap",
  "version": "0.1.2",
  "description": "Kengela AD/LDAP directory adapter: LDAP(S) bind, paginated search, normalization to LdapEntryParts and DirectoryProfile.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-dist-markers.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kengela/iam-mapping": "workspace:*",
    "ldapts": "^8.1.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannds/kengela.git",
    "directory": "packages/adapter-directory-ldap"
  },
  "module": "./dist/esm/index.js",
  "homepage": "https://github.com/yannds/kengela/wiki",
  "bugs": {
    "url": "https://github.com/yannds/kengela/issues"
  },
  "author": "yannds",
  "keywords": [
    "kengela",
    "zero-trust",
    "ztna",
    "iam",
    "identity",
    "authentication",
    "authorization",
    "rbac",
    "abac",
    "multi-tenant",
    "typescript",
    "esm",
    "ldap",
    "active-directory",
    "ldaps"
  ]
}
