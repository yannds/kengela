{
  "name": "@kengela/iam-mapping",
  "version": "0.1.0",
  "description": "Kengela — normalisation d'identité IdP pure : OIDC/SCIM/SAML/LDAP/Graph/Google → DirectoryProfile + moteur de mapping rôles.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-dist-markers.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannds/kengela.git",
    "directory": "packages/iam-mapping"
  },
  "module": "./dist/esm/index.js"
}
