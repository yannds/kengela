{
  "name": "@kengela/nestjs",
  "version": "0.1.3",
  "description": "Kengela NestJS integration: authorization guard (PDP) + decorators.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-dist-markers.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kengela/contracts": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "reflect-metadata": ">=0.1.13"
  },
  "devDependencies": {
    "@kengela/authz-core": "workspace:*",
    "@kengela/adapter-expr-cel": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannds/kengela.git",
    "directory": "packages/nestjs"
  },
  "module": "./dist/esm/index.js",
  "homepage": "https://github.com/yannds/kengela/wiki",
  "bugs": {
    "url": "https://github.com/yannds/kengela/issues"
  },
  "author": "yannds",
  "keywords": [
    "kengela",
    "zero-trust",
    "ztna",
    "iam",
    "identity",
    "authentication",
    "authorization",
    "rbac",
    "abac",
    "multi-tenant",
    "typescript",
    "esm",
    "nestjs",
    "guard",
    "decorators"
  ]
}
