{
  "name": "@kengela/adapter-authn-better-auth",
  "version": "0.1.5",
  "description": "Kengela IdentityPort adapter on top of a better-auth instance (OIDC/OAuth/SSO).",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-dist-markers.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kengela/contracts": "workspace:*"
  },
  "peerDependencies": {
    "better-auth": ">=1"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannds/kengela.git",
    "directory": "packages/adapter-authn-better-auth"
  },
  "module": "./dist/esm/index.js",
  "homepage": "https://github.com/yannds/kengela/wiki",
  "bugs": {
    "url": "https://github.com/yannds/kengela/issues"
  },
  "author": "yannds",
  "keywords": [
    "kengela",
    "zero-trust",
    "ztna",
    "iam",
    "identity",
    "authentication",
    "authorization",
    "rbac",
    "abac",
    "multi-tenant",
    "typescript",
    "esm",
    "better-auth",
    "oauth",
    "oidc",
    "sso"
  ]
}
