{
  "name": "@kengela/adapter-authn-native",
  "version": "0.1.3",
  "description": "Kengela hardened native authn: timing-safe credentials, AES-256-GCM encryption, TOTP.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ../../scripts/write-dist-markers.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kengela/contracts": "workspace:*",
    "bcryptjs": "^3.0.3",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "@node-rs/argon2": "^2.0.2"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannds/kengela.git",
    "directory": "packages/adapter-authn-native"
  },
  "module": "./dist/esm/index.js",
  "homepage": "https://github.com/yannds/kengela/wiki",
  "bugs": {
    "url": "https://github.com/yannds/kengela/issues"
  },
  "author": "yannds",
  "keywords": [
    "kengela",
    "zero-trust",
    "ztna",
    "iam",
    "identity",
    "authentication",
    "authorization",
    "rbac",
    "abac",
    "multi-tenant",
    "typescript",
    "esm",
    "argon2",
    "bcrypt",
    "totp",
    "mfa",
    "aes-gcm"
  ]
}
