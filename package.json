{
  "name": "kengela",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Kengela - Zero Trust identity & access (authn + authz) for multi-tenant apps. Le veilleur.",
  "license": "Apache-2.0",
  "author": "yannds",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:arch": "depcruise packages --config .dependency-cruiser.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
